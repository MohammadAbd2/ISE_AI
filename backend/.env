# ═══════════════════════════════════════════════════════════════════════════
# ISE AI — Environment Configuration
# Copy this file to .env and adjust the values for your system.
# ═══════════════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────────
APP_NAME=ISE AI
ENVIRONMENT=development

# ── Ollama ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Model selection: set to "auto" to let ISE AI pick the best model
# for your hardware, or specify an exact model name.
#
# Hardware tiers:
#   < 6  GB RAM  → qwen2.5:3b
#   6-12 GB RAM  → qwen2.5-coder:7b
#   12-22 GB RAM → qwen2.5-coder:14b   ← recommended for most PCs
#   22-44 GB RAM → qwen3-30b-a3b
#   44+  GB RAM  → qwen2.5:72b
#
DEFAULT_MODEL=auto
CODING_MODEL=auto
REASONING_MODEL=auto

# Context window — auto-scaled based on hardware tier when set to 0
OLLAMA_NUM_CTX=8192

# Comma-separated fallback models (tried in order if primary unavailable)
OLLAMA_FALLBACK_MODELS=qwen2.5-coder:14b,qwen2.5-coder:7b,qwen2.5:7b,llama3.1:8b,llama3.2:3b

# ── Vision / Image (optional) ───────────────────────────────────────────
# OLLAMA_VISION_MODEL=llava:13b
# OLLAMA_IMAGE_MODEL=

# ── Self-improvement ─────────────────────────────────────────────────────
# Apply validated self-rewrites automatically (still requires user approval)
SELF_REWRITE_APPLY_ON_SUCCESS=true
SELF_REWRITE_WORKSPACE=.ise_ai_self_rewrites

# ── Sandbox ──────────────────────────────────────────────────────────────
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=30
DOCKER_ENABLED=false

# ── Database (optional — uses in-memory if not set) ─────────────────────
# CHROMA_PATH=backend/.chroma
# CHROMA_TENANT=default_tenant
# CHROMA_DATABASE=default_database

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://localhost:5173,https://127.0.0.1:5173,http://localhost:3000

# ── Tool context ─────────────────────────────────────────────────────────
MAX_TOOL_CONTEXT_CHARS=32000
